{% liquid
  assign section_id = 'ramblier-coming-soon-' | append: section.id
  assign rotating_words_count = section.blocks.size
%}

<section
  id="{{ section_id }}"
  class="ramblier-coming-soon"
  style="
    --rcs-bg: {{ section.settings.bg_color }};
    --rcs-bg-overlay: {{ section.settings.bg_overlay_color }};
    --rcs-text: {{ section.settings.text_color }};
    --rcs-muted: {{ section.settings.muted_color }};
    --rcs-line: {{ section.settings.line_color }};
    --rcs-page-width: {{ section.settings.page_width }}px;
    --rcs-section-height: {{ section.settings.section_height }}vh;
    --rcs-content-width: {{ section.settings.content_max_width }}px;
    --rcs-logo-width: {{ section.settings.logo_width }}px;
    --rcs-pattern-width: {{ section.settings.pattern_width }}%;
    --rcs-pattern-opacity: {{ section.settings.pattern_opacity | divided_by: 100.0 }};
    --rcs-top-spacing: {{ section.settings.top_spacing }}px;
    --rcs-bottom-spacing: {{ section.settings.bottom_spacing }}px;
    --rcs-eyebrow-size: {{ section.settings.eyebrow_size }}px;
    --rcs-heading-size: {{ section.settings.heading_size }}px;
    --rcs-heading-mobile-size: {{ section.settings.heading_mobile_size }}px;
    --rcs-subheading-size: {{ section.settings.subheading_size }}px;
    --rcs-subheading-mobile-size: {{ section.settings.subheading_mobile_size }}px;
    --rcs-rotating-word-size: {{ section.settings.rotating_word_size }}px;
    --rcs-rotating-word-mobile-size: {{ section.settings.rotating_word_mobile_size }}px;
    --rcs-form-input-size: {{ section.settings.form_input_size }}px;
    --rcs-form-button-size: {{ section.settings.form_button_size }}px;
    --rcs-social-size: {{ section.settings.social_size }}px;
    --rcs-social-icon-size: {{ section.settings.social_icon_size }}px;
    --rcs-border-radius: {{ section.settings.border_radius }}px;
  "
>
  <script>
    (() => {
      const initRamblierComingSoon = () => {
        const section = document.getElementById('{{ section_id }}');
        if (!section || section.dataset.rotatorInitialized === 'true') return;

        const rotatingWord = section.querySelector('.js-ramblier-rotating-word');
        if (!rotatingWord) return;

        const words = [];
        {% for block in section.blocks %}
          {% if block.settings.word != blank %}
            words.push({{ block.settings.word | json }});
          {% endif %}
        {% endfor %}

        if (!words.length) return;

        const holdDelay = {{ section.settings.word_switch_interval | times: 1000 }};
        const typingSpeed = 90;
        const deletingSpeed = 45;

        let currentIndex = 0;
        let currentTimeout = null;
        let isStopped = false;

        const clearCurrentTimeout = () => {
          if (currentTimeout) {
            window.clearTimeout(currentTimeout);
            currentTimeout = null;
          }
        };

        const typeWord = (word, charIndex = 0) => {
          if (isStopped) return;

          rotatingWord.textContent = word.slice(0, charIndex);

          if (charIndex < word.length) {
            currentTimeout = window.setTimeout(() => {
              typeWord(word, charIndex + 1);
            }, typingSpeed);
          } else {
            currentTimeout = window.setTimeout(() => {
              deleteWord(word, word.length);
            }, holdDelay);
          }
        };

        const deleteWord = (word, charIndex) => {
          if (isStopped) return;

          rotatingWord.textContent = word.slice(0, charIndex);

          if (charIndex > 0) {
            currentTimeout = window.setTimeout(() => {
              deleteWord(word, charIndex - 1);
            }, deletingSpeed);
          } else {
            currentIndex = (currentIndex + 1) % words.length;
            currentTimeout = window.setTimeout(() => {
              typeWord(words[currentIndex], 1);
            }, 120);
          }
        };

        const startRotation = () => {
          isStopped = false;
          clearCurrentTimeout();

          const currentWord = words[currentIndex];
          rotatingWord.textContent = '';
          typeWord(currentWord, 1);
        };

        const stopRotation = () => {
          isStopped = true;
          clearCurrentTimeout();
        };

        section.dataset.rotatorInitialized = 'true';

        document.addEventListener('visibilitychange', () => {
          if (document.hidden) {
            stopRotation();
          } else {
            startRotation();
          }
        });

        startRotation();
      };

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initRamblierComingSoon);
      } else {
        initRamblierComingSoon();
      }

      document.addEventListener('shopify:section:load', initRamblierComingSoon);
    })();
  </script>

  <div class="ramblier-coming-soon__bg"></div>

  {% if section.settings.pattern_image != blank %}
    <div class="ramblier-coming-soon__pattern-wrap" aria-hidden="true">
      {{
        section.settings.pattern_image
        | image_url: width: 2800
        | image_tag:
          class: 'ramblier-coming-soon__pattern-image',
          loading: 'lazy',
          widths: '900, 1200, 1600, 2000, 2400, 2800',
          sizes: '100vw'
      }}
    </div>
  {% endif %}

  <div class="ramblier-coming-soon__inner page-width">
    <div class="ramblier-coming-soon__content">
      {% if section.settings.logo_image != blank %}
        <div class="ramblier-coming-soon__logo-wrap">
          {{
            section.settings.logo_image
            | image_url: width: 1400
            | image_tag:
              class: 'ramblier-coming-soon__logo-image',
              loading: 'eager',
              widths: '300, 500, 700, 900, 1200, 1400',
              sizes: '(max-width: 768px) 240px, 520px'
          }}
        </div>
      {% else %}
        <div class="ramblier-coming-soon__logo-text">
          {{ section.settings.brand_name }}
        </div>
      {% endif %}

      {% if section.settings.eyebrow != blank %}
        <p class="ramblier-coming-soon__eyebrow">
          {{ section.settings.eyebrow }}
        </p>
      {% endif %}

      <h1 class="ramblier-coming-soon__heading">
        {% if section.settings.heading_prefix != blank %}
          <span>{{ section.settings.heading_prefix }}</span>
        {% endif %}

        <span class="ramblier-coming-soon__rotating-wrap">
          <span class="js-ramblier-rotating-word ramblier-coming-soon__rotating-word">
            {% if section.blocks.size > 0 and section.blocks.first.settings.word != blank %}
              {{ section.blocks.first.settings.word }}
            {% else %}
              {{ section.settings.fallback_rotating_word }}
            {% endif %}
          </span>
          <span class="ramblier-coming-soon__drawn-underline" aria-hidden="true">
            <svg viewBox="0 0 210 18" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path
                d="M4 13.5C35 10 63 8 91 7.5C122 7 153 8.5 184 12C191 12.8 198 13.6 206 14.8"
                stroke="currentColor"
                stroke-width="3"
                stroke-linecap="round"
              />
            </svg>
          </span>
        </span>

        {% if section.settings.heading_suffix != blank %}
          <span>{{ section.settings.heading_suffix }}</span>
        {% endif %}
      </h1>

      {% if section.settings.subheading != blank %}
        <div class="ramblier-coming-soon__subheading">
          {{ section.settings.subheading }}
        </div>
      {% endif %}

      <div class="ramblier-coming-soon__form-wrap">
        {% if section.settings.klaviyo_embed != blank %}
          <div class="ramblier-coming-soon__klaviyo">
            {{ section.settings.klaviyo_embed }}
          </div>
        {% else %}
          <div class="ramblier-coming-soon__placeholder">Paste your Klaviyo embed code in the section settings.</div>
        {% endif %}
      </div>

      {% assign has_socials = false %}
      {% if section.settings.pinterest_url != blank
        or section.settings.instagram_url != blank
        or section.settings.tiktok_url != blank
      %}
        {% assign has_socials = true %}
      {% endif %}

      {% if has_socials %}
        <div class="ramblier-coming-soon__socials">
          {% if section.settings.pinterest_url != blank %}
            <a
              href="{{ section.settings.pinterest_url }}"
              class="ramblier-coming-soon__social-link"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Pinterest"
            >
              <span class="ramblier-coming-soon__social-shape">
                <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                  <path d="M12.04 2C6.73 2 4 5.8 4 9.94c0 2.45.93 4.62 2.93 5.43.33.14.63.01.73-.36.07-.25.22-.88.29-1.14.1-.36.06-.49-.21-.81-.59-.7-.96-1.59-.96-2.87 0-3.69 2.76-6.99 7.19-6.99 3.92 0 6.08 2.4 6.08 5.61 0 4.22-1.87 7.79-4.65 7.79-1.53 0-2.67-1.27-2.3-2.82.44-1.85 1.28-3.84 1.28-5.17 0-1.19-.64-2.19-1.96-2.19-1.56 0-2.81 1.61-2.81 3.77 0 1.37.46 2.29.46 2.29l-1.86 7.9c-.55 2.34-.08 5.2-.04 5.49.02.17.24.21.34.08.14-.18 1.93-2.39 2.54-4.59.17-.63.98-3.88.98-3.88.48.92 1.87 1.73 3.36 1.73 4.42 0 7.42-4.03 7.42-9.42C22 5.79 17.8 2 12.04 2Z" fill="currentColor"/>
                </svg>
              </span>
            </a>
          {% endif %}

          {% if section.settings.instagram_url != blank %}
            <a
              href="{{ section.settings.instagram_url }}"
              class="ramblier-coming-soon__social-link"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Instagram"
            >
              <span class="ramblier-coming-soon__social-shape">
                <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                  <path d="M7.75 2h8.5A5.75 5.75 0 0 1 22 7.75v8.5A5.75 5.75 0 0 1 16.25 22h-8.5A5.75 5.75 0 0 1 2 16.25v-8.5A5.75 5.75 0 0 1 7.75 2Zm0 1.8A3.95 3.95 0 0 0 3.8 7.75v8.5a3.95 3.95 0 0 0 3.95 3.95h8.5a3.95 3.95 0 0 0 3.95-3.95v-8.5a3.95 3.95 0 0 0-3.95-3.95Zm8.95 1.35a1.1 1.1 0 1 1 0 2.2 1.1 1.1 0 0 1 0-2.2ZM12 6.4A5.6 5.6 0 1 1 6.4 12 5.6 5.6 0 0 1 12 6.4Zm0 1.8A3.8 3.8 0 1 0 15.8 12 3.8 3.8 0 0 0 12 8.2Z" fill="currentColor"/>
                </svg>
              </span>
            </a>
          {% endif %}

          {% if section.settings.tiktok_url != blank %}
            <a
              href="{{ section.settings.tiktok_url }}"
              class="ramblier-coming-soon__social-link"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="TikTok"
            >
              <span class="ramblier-coming-soon__social-shape">
                <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                  <path d="M14.57 2h2.47c.2 1.7 1.16 3.23 2.63 4.08.87.51 1.88.8 2.93.83v2.53c-1.16-.04-2.3-.31-3.33-.78a7.48 7.48 0 0 1-2.22-1.54l-.01 8.04c0 1.62-.63 3.15-1.79 4.3A6.08 6.08 0 0 1 11 22a6.1 6.1 0 0 1-4.3-1.78A6.04 6.04 0 0 1 5 15.93c0-1.62.63-3.15 1.79-4.3A6.07 6.07 0 0 1 11.1 10c.39 0 .78.04 1.16.12v2.57a3.61 3.61 0 0 0-1.16-.19c-.96 0-1.86.38-2.54 1.05a3.57 3.57 0 0 0-1.05 2.54c0 .96.37 1.86 1.05 2.54A3.57 3.57 0 0 0 11.1 19.7c.96 0 1.86-.37 2.54-1.05a3.57 3.57 0 0 0 1.05-2.54V2Z" fill="currentColor"/>
                </svg>
              </span>
            </a>
          {% endif %}
        </div>
      {% endif %}
    </div>
  </div>

  <style>
        #{{ section_id }} {
          position: relative;
          overflow: hidden;
          min-height: var(--rcs-section-height);
          display: flex;
          align-items: center;
          justify-content: center;
          background: var(--rcs-bg);
          color: var(--rcs-text);
          padding-top: var(--rcs-top-spacing);
          padding-bottom: var(--rcs-bottom-spacing);
        }

        #{{ section_id }} .page-width {
          width: 100%;
          max-width: var(--rcs-page-width);
          margin: 0 auto;
          padding-left: 24px;
          padding-right: 24px;
        }

        #{{ section_id }} .ramblier-coming-soon__bg {
          position: absolute;
          inset: 0;
          background: linear-gradient(180deg, var(--rcs-bg) 0%, var(--rcs-bg-overlay) 100%);
          z-index: 0;
        }

        #{{ section_id }} .ramblier-coming-soon__pattern-wrap {
          position: absolute;
          inset: 0;
          z-index: 1;
          display: flex;
          align-items: center;
          justify-content: center;
          pointer-events: none;
          overflow: hidden;
        }

        #{{ section_id }} .ramblier-coming-soon__pattern-image {
          width: var(--rcs-pattern-width);
          max-width: none;
          height: auto;
          display: block;
          opacity: var(--rcs-pattern-opacity);
          object-fit: contain;
          object-position: center;
          filter: grayscale(1) brightness(0.8);
          mix-blend-mode: screen;
        }

        #{{ section_id }} .ramblier-coming-soon__inner {
          position: relative;
          z-index: 2;
          width: 100%;
        }

        #{{ section_id }} .ramblier-coming-soon__content {
          width: 100%;
          max-width: var(--rcs-content-width);
          margin: 0 auto;
          display: flex;
          flex-direction: column;
          align-items: center;
          text-align: center;
        }

        #{{ section_id }} .ramblier-coming-soon__logo-wrap {
          width: 100%;
          display: flex;
          justify-content: center;
          margin-bottom: 26px;
        }

        #{{ section_id }} .ramblier-coming-soon__logo-image {
          width: min(100%, var(--rcs-logo-width));
          height: auto;
          display: block;
        }

        #{{ section_id }} .ramblier-coming-soon__logo-text {
          margin-bottom: 26px;
          color: var(--rcs-text);
          font-size: 64px;
          line-height: 0.95;
          font-weight: 700;
          letter-spacing: 0.01em;
          text-transform: uppercase;
        }

        #{{ section_id }} .ramblier-coming-soon__eyebrow {
          margin: 0 0 18px;
          color: var(--rcs-text);
          font-size: var(--rcs-eyebrow-size);
          line-height: 1;
          letter-spacing: 0.18em;
          text-transform: uppercase;
          opacity: 0.95;
        }

        #{{ section_id }} .ramblier-coming-soon__heading {
          margin: 0;
          color: var(--rcs-text);
          font-size: var(--rcs-heading-size);
          line-height: 1;
          letter-spacing: 0;
          text-transform: uppercase;
          display: flex;
          flex-wrap: wrap;
          align-items: flex-end;
          justify-content: center;
          gap: 0.2em 0.26em;
        }

        #{{ section_id }} .ramblier-coming-soon__rotating-wrap {
          position: relative;
          display: inline-flex;
          flex-direction: column;
          align-items: center;
          justify-content: flex-start;
          overflow: visible;
          padding: 0 0.08em;
        }

    #{{ section_id }} .ramblier-coming-soon__rotating-word {
      display: inline-block;
      min-width: 3.6ch;
      font-size: var(--rcs-rotating-word-size);
      line-height: 0.9;
      font-style: italic;
      font-weight: 500;
      text-transform: none;
      white-space: nowrap;
      vertical-align: baseline;
          font-family: Dear Jocelyn, cursive;
    }

    #{{ section_id }} .ramblier-coming-soon__rotating-word::after {
  content: '';
  display: inline-block;
  width: 1px;
  height: 0.9em;
  margin-left: 0.08em;
  background: currentColor;
  vertical-align: -0.08em;
  animation: ramblierComingSoonBlink 0.9s steps(1) infinite;
}

@keyframes ramblierComingSoonBlink {
  0%, 50% {
    opacity: 1;
  }
  50.01%, 100% {
    opacity: 0;
  }
}

        #{{ section_id }} .ramblier-coming-soon__drawn-underline {
          display: block;
          width: 100%;
          line-height: 0;
          margin-top: -2px;
        }

        #{{ section_id }} .ramblier-coming-soon__drawn-underline svg {
          width: 100%;
          min-width: 110px;
          height: auto;
          display: block;
          color: var(--rcs-line);
        }

        #{{ section_id }} .ramblier-coming-soon__subheading {
          margin-top: 16px;
          color: var(--rcs-text);
          font-size: var(--rcs-subheading-size);
          line-height: 1.35;
          opacity: 0.95;
          max-width: 760px;
        }

        #{{ section_id }} .ramblier-coming-soon__subheading p {
          margin: 0;
        }

        #{{ section_id }} .ramblier-coming-soon__form-wrap {
          width: 100%;
          margin-top: 34px;
        }

        #{{ section_id }} .ramblier-coming-soon__placeholder {
          width: 100%;
          padding: 18px 20px;
          border: 1px dashed rgba(255, 255, 255, 0.35);
          border-radius: var(--rcs-border-radius);
          color: var(--rcs-muted);
          font-size: 15px;
          line-height: 1.5;
          text-align: center;
        }

        #{{ section_id }} .ramblier-coming-soon__klaviyo {
          width: 100%;
        }

        #{{ section_id }} .ramblier-coming-soon__klaviyo > div,
        #{{ section_id }} .ramblier-coming-soon__klaviyo > div > div,
        #{{ section_id }} .ramblier-coming-soon__klaviyo form {
          width: 100% !important;
          max-width: 100% !important;
        }

        #{{ section_id }} .ramblier-coming-soon__klaviyo [data-testid="form-row"],
        #{{ section_id }} .ramblier-coming-soon__klaviyo .needsclick.kl-private-reset-css-Xuajs1,
        #{{ section_id }} .ramblier-coming-soon__klaviyo .klaviyo-form {
          width: 100% !important;
        }

        #{{ section_id }} .ramblier-coming-soon__klaviyo form,
        #{{ section_id }} .ramblier-coming-soon__klaviyo .go3176171171,
        #{{ section_id }} .ramblier-coming-soon__klaviyo .go3176171171 form {
          background: transparent !important;
          box-shadow: none !important;
          border: 0 !important;
          padding: 0 !important;
          margin: 0 !important;
        }

        #{{ section_id }} .ramblier-coming-soon__klaviyo input[type="email"],
        #{{ section_id }} .ramblier-coming-soon__klaviyo input[type="text"],
        #{{ section_id }} .ramblier-coming-soon__klaviyo input[type="search"] {
          width: 100% !important;
          min-height: 42px !important;
          background: transparent !important;
          color: var(--rcs-text) !important;
          border: 0 !important;
          border-bottom: 1px solid var(--rcs-line) !important;
          border-radius: 0 !important;
          box-shadow: none !important;
          outline: none !important;
          padding: 0 120px 12px 0 !important;
          margin: 0 !important;
          font-size: var(--rcs-form-input-size) !important;
          line-height: 1.2 !important;
          text-align: left !important;
          appearance: none !important;
          -webkit-appearance: none !important;
        }

        #{{ section_id }} .ramblier-coming-soon__klaviyo input[type="email"]::placeholder,
        #{{ section_id }} .ramblier-coming-soon__klaviyo input[type="text"]::placeholder,
        #{{ section_id }} .ramblier-coming-soon__klaviyo input[type="search"]::placeholder {
          color: var(--rcs-muted) !important;
          opacity: 1 !important;
        }

        #{{ section_id }} .ramblier-coming-soon__klaviyo button,
        #{{ section_id }} .ramblier-coming-soon__klaviyo input[type="submit"] {
          background: transparent !important;
          border: 0 !important;
          box-shadow: none !important;
          color: var(--rcs-text) !important;
          text-transform: uppercase !important;
          letter-spacing: 0.12em !important;
          font-size: var(--rcs-form-button-size) !important;
          line-height: 1 !important;
          font-weight: 600 !important;
          padding: 0 !important;
          margin: 0 !important;
          min-height: auto !important;
          cursor: pointer !important;
          transition: opacity 0.2s ease, transform 0.2s ease !important;
        }

        #{{ section_id }} .ramblier-coming-soon__klaviyo button:hover,
        #{{ section_id }} .ramblier-coming-soon__klaviyo input[type="submit"]:hover {
          opacity: 0.75 !important;
          transform: translateY(-1px) !important;
        }

        #{{ section_id }} .ramblier-coming-soon__klaviyo p,
        #{{ section_id }} .ramblier-coming-soon__klaviyo span,
        #{{ section_id }} .ramblier-coming-soon__klaviyo label,
        #{{ section_id }} .ramblier-coming-soon__klaviyo div {
          color: inherit;
        }

        #{{ section_id }} .ramblier-coming-soon__klaviyo [role="status"],
        #{{ section_id }} .ramblier-coming-soon__klaviyo .success_message,
        #{{ section_id }} .ramblier-coming-soon__klaviyo .error_message {
          margin-top: 16px !important;
          font-size: 14px !important;
          line-height: 1.5 !important;
          text-align: center !important;
        }

        #{{ section_id }} .ramblier-coming-soon__socials {
          display: flex;
          align-items: center;
          justify-content: center;
          gap: 14px;
          flex-wrap: wrap;
          margin-top: 34px;
        }

        #{{ section_id }} .ramblier-coming-soon__social-link {
          display: inline-flex;
          align-items: center;
          justify-content: center;
          color: var(--rcs-text);
          text-decoration: none;
          transition: opacity 0.2s ease, transform 0.2s ease;
        }

        #{{ section_id }} .ramblier-coming-soon__social-link:hover {
          opacity: 0.75;
          transform: translateY(-1px);
        }

        #{{ section_id }} .ramblier-coming-soon__social-shape {
          width: var(--rcs-social-size);
          height: calc(var(--rcs-social-size) * 1.08);
          display: flex;
          align-items: center;
          justify-content: center;
          border: 1px solid var(--rcs-line);
          clip-path: polygon(25% 6.7%, 75% 6.7%, 100% 50%, 75% 93.3%, 25% 93.3%, 0% 50%);
        }

        #{{ section_id }} .ramblier-coming-soon__social-shape svg {
          width: var(--rcs-social-icon-size);
          height: var(--rcs-social-icon-size);
          display: block;
          color: currentColor;
          flex: 0 0 auto;
        }

        @media screen and (max-width: 989px) {
          #{{ section_id }} {
            min-height: auto;
          }

          #{{ section_id }} .ramblier-coming-soon__pattern-image {
            width: 180%;
          }

          #{{ section_id }} .ramblier-coming-soon__heading {
            font-size: var(--rcs-heading-mobile-size);
            line-height: 1.02;
          }

          #{{ section_id }} .ramblier-coming-soon__rotating-word {
            font-size: var(--rcs-rotating-word-mobile-size);
          }

          #{{ section_id }} .ramblier-coming-soon__logo-text {
            font-size: 48px;
          }
        }

        @media screen and (max-width: 749px) {
          #{{ section_id }} .page-width {
            padding-left: 20px;
            padding-right: 20px;
          }

          #{{ section_id }} .ramblier-coming-soon__logo-wrap {
            margin-bottom: 22px;
          }

          #{{ section_id }} .ramblier-coming-soon__eyebrow {
            margin-bottom: 14px;
            letter-spacing: 0.16em;
          }

          #{{ section_id }} .ramblier-coming-soon__subheading {
