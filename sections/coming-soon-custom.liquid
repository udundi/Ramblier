    --rcs-bg-image-opacity: 0.2;
    --rcs-bg-image-scale: 1.03;
  }
}

    @media screen and (max-width: 749px) {
      #{{ section_id }} .page-width {
        padding-left: 20px;
        padding-right: 20px;
      }

      #{{ section_id }} .ramblier-coming-soon__logo-wrap {
        margin-bottom: 22px;
      }

      #{{ section_id }} .ramblier-coming-soon__eyebrow {
        margin-bottom: 14px;
        letter-spacing: 0.16em;
      }

      #{{ section_id }} .ramblier-coming-soon__subheading {
        font-size: var(--rcs-subheading-mobile-size);
      }

      #{{ section_id }} .ramblier-coming-soon__input {
        padding-right: 94px;
        min-height: 38px;
      }

