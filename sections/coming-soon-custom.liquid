{% liquid
  assign section_id = 'ramblier-coming-soon-' | append: section.id
%}

<section
  id="{{ section_id }}"
  class="ramblier-coming-soon"
  style="
    --rcs-bg: {{ section.settings.bg_color }};
    --rcs-bg-overlay: {{ section.settings.bg_overlay_color }};
    --rcs-text: {{ section.settings.text_color }};
    --rcs-muted: {{ section.settings.muted_color }};
    --rcs-line: {{ section.settings.line_color }};
    --rcs-page-width: {{ section.settings.page_width }}px;
    --rcs-section-height: {{ section.settings.section_height }}vh;
    --rcs-content-width: {{ section.settings.content_max_width }}px;
    --rcs-logo-width: {{ section.settings.logo_width }}px;
    --rcs-bg-image-scale: {{ section.settings.bg_image_scale | divided_by: 100.0 }};
    --rcs-bg-image-opacity: {{ section.settings.bg_image_opacity | divided_by: 100.0 }};
    --rcs-bg-image-blur: {{ section.settings.bg_image_blur }}px;
    --rcs-top-spacing: {{ section.settings.top_spacing }}px;
    --rcs-bottom-spacing: {{ section.settings.bottom_spacing }}px;
    --rcs-eyebrow-size: {{ section.settings.eyebrow_size }}px;
    --rcs-heading-size: {{ section.settings.heading_size }}px;
    --rcs-heading-mobile-size: {{ section.settings.heading_mobile_size }}px;
    --rcs-subheading-size: {{ section.settings.subheading_size }}px;
    --rcs-subheading-mobile-size: {{ section.settings.subheading_mobile_size }}px;
    --rcs-rotating-word-size: {{ section.settings.rotating_word_size }}px;
    --rcs-rotating-word-mobile-size: {{ section.settings.rotating_word_mobile_size }}px;
    --rcs-form-input-size: {{ section.settings.form_input_size }}px;
    --rcs-form-button-size: {{ section.settings.form_button_size }}px;
    --rcs-social-size: {{ section.settings.social_size }}px;
    --rcs-social-icon-size: {{ section.settings.social_icon_size }}px;
    --rcs-border-radius: {{ section.settings.border_radius }}px;
  "
>
  <script>
    (() => {
      const initRamblierComingSoon = (event) => {
        const section = document.getElementById('{{ section_id }}');
        if (!section || section.dataset.ramblierInitialized === 'true') return;

        section.dataset.ramblierInitialized = 'true';

        const rotatingWord = section.querySelector('.js-ramblier-rotating-word');
        const rotatingWrap = section.querySelector('.ramblier-coming-soon__rotating-wrap');

        const words = [];
        {% for block in section.blocks %}
          {% if block.settings.word != blank %}
            words.push({{ block.settings.word | json }});
          {% endif %}
        {% endfor %}

        if (rotatingWord && words.length) {
          const holdDelay = {{ section.settings.word_switch_interval | times: 1000 }};
          const typingSpeed = 90;
          const deletingSpeed = 45;

          let currentIndex = 0;
          let currentTimeout = null;
          let isStopped = false;

          const clearCurrentTimeout = () => {
            if (currentTimeout) {
              window.clearTimeout(currentTimeout);
              currentTimeout = null;
            }
          };

          const syncRotatingWidth = () => {
            if (!rotatingWrap || !rotatingWord) return;
            rotatingWrap.style.width = rotatingWord.offsetWidth + 'px';
          };

          const typeWord = (word, charIndex = 0) => {
            if (isStopped) return;

            rotatingWord.textContent = word.slice(0, charIndex);
            syncRotatingWidth();

            if (charIndex < word.length) {
              currentTimeout = window.setTimeout(() => {
                typeWord(word, charIndex + 1);
              }, typingSpeed);
            } else {
              currentTimeout = window.setTimeout(() => {
                deleteWord(word, word.length);
              }, holdDelay);
            }
          };

          const deleteWord = (word, charIndex) => {
            if (isStopped) return;

            rotatingWord.textContent = word.slice(0, charIndex);
            syncRotatingWidth();

            if (charIndex > 0) {
              currentTimeout = window.setTimeout(() => {
                deleteWord(word, charIndex - 1);
              }, deletingSpeed);
            } else {
              currentIndex = (currentIndex + 1) % words.length;
              currentTimeout = window.setTimeout(() => {
                typeWord(words[currentIndex], 1);
              }, 120);
            }
          };

          const startRotation = () => {
            isStopped = false;
            clearCurrentTimeout();

            const currentWord = words[currentIndex];
            rotatingWord.textContent = '';
            syncRotatingWidth();
            typeWord(currentWord, 1);
          };

          const stopRotation = () => {
            isStopped = true;
            clearCurrentTimeout();
          };

          document.addEventListener('visibilitychange', () => {
            if (document.hidden) {
              stopRotation();
            } else {
              startRotation();
            }
          });

          startRotation();
        }

        const form = section.querySelector('.ramblier-coming-soon__form');
        const emailInput = section.querySelector('.ramblier-coming-soon__input');
        const submitButton = section.querySelector('.ramblier-coming-soon__submit');
        const messageEl = section.querySelector('.ramblier-coming-soon__form-message');

        const companyId = {{ section.settings.klaviyo_public_api_key | json }};
        const listId = {{ section.settings.klaviyo_list_id | json }};
        const signupSource = {{ section.settings.waitlist_source | json }};
        const signupPage = window.location.pathname;

        const setMessage = (message, type = '') => {
          if (!messageEl) return;
          messageEl.textContent = message || '';
          messageEl.classList.remove('is-error', 'is-success');
          if (type) {
            messageEl.classList.add(type);
          }
        };

        const isValidEmail = (email) => {
          return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email);
        };

        const createOrUpdateProfile = async (email) => {
          const response = await fetch(
            `https://a.klaviyo.com/client/profiles/?company_id=${encodeURIComponent(companyId)}`,
            {
              method: 'POST',
              headers: {
                'Content-Type': 'application/json',
                'revision': '2026-04-15'
              },
              body: JSON.stringify({
                data: {
                  type: 'profile',
                  attributes: {
                    email: email,
                    properties: {
                      signup_source: signupSource,
                      signup_page: signupPage,
                      signup_type: 'waitlist'
                    }
                  }
                }
              })
            }
          );

          if (!response.ok && response.status !== 202) {
            throw new Error('Profile update failed');
          }
        };

        const subscribeProfile = async (email) => {
          const payload = {
            data: {
              type: 'subscription',
              attributes: {
                profile: {
                  data: {
                    type: 'profile',
                    attributes: {
                      email: email,
                      subscriptions: {
                        email: {
                          marketing: {
                            consent: 'SUBSCRIBED'
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          };

          if (listId) {
            payload.data.relationships = {
              list: {
                data: {
                  type: 'list',
                  id: listId
                }
              }
            };
          }

          const response = await fetch(
            `https://a.klaviyo.com/client/subscriptions/?company_id=${encodeURIComponent(companyId)}`,
            {
              method: 'POST',
              headers: {
                'Content-Type': 'application/json',
                'revision': '2026-04-15'
              },
              body: JSON.stringify(payload)
            }
          );

          if (!response.ok && response.status !== 202) {
            throw new Error('Subscription failed');
          }
        };

        if (form && emailInput && submitButton && messageEl) {
          form.addEventListener('submit', async (event) => {
            event.preventDefault();

            const email = (emailInput.value || '').trim();

            setMessage('');

            if (!companyId) {
              setMessage('Add your Klaviyo public API key in the section settings.', 'is-error');
              return;
            }

            if (!listId) {
              setMessage('Add your Klaviyo list ID in the section settings.', 'is-error');
              return;
            }

            if (!email || !isValidEmail(email)) {
              setMessage({{ section.settings.invalid_email_message | json }}, 'is-error');
              return;
            }

            form.classList.add('is-submitting');
            submitButton.setAttribute('aria-busy', 'true');

            try {
              await createOrUpdateProfile(email);
              await subscribeProfile(email);
              form.reset();
              setMessage({{ section.settings.success_message | json }}, 'is-success');
            } catch (error) {
              console.error('Ramblier waitlist submission error:', error);
              setMessage({{ section.settings.error_message | json }}, 'is-error');
            } finally {
              form.classList.remove('is-submitting');
              submitButton.removeAttribute('aria-busy');
            }
          });
        }
      };

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initRamblierComingSoon);
      } else {
        initRamblierComingSoon();
      }

      document.addEventListener('shopify:section:load', initRamblierComingSoon);
    })();
  </script>

  <div class="ramblier-coming-soon__bg"></div>

  {% if section.settings.background_image != blank %}
    <div class="ramblier-coming-soon__bg-image-wrap" aria-hidden="true">
      {{
        section.settings.background_image
        | image_url: width: 2800
        | image_tag:
          class: 'ramblier-coming-soon__bg-image',
          loading: 'lazy',
          widths: '900, 1200, 1600, 2000, 2400, 2800',
          sizes: '100vw'
      }}
    </div>
  {% endif %}

  <div class="ramblier-coming-soon__inner page-width">
    <div class="ramblier-coming-soon__content">
      {% if section.settings.logo_image != blank %}
        <div class="ramblier-coming-soon__logo-wrap">
          {{
            section.settings.logo_image
            | image_url: width: 1400
            | image_tag:
              class: 'ramblier-coming-soon__logo-image',
              loading: 'eager',
              widths: '300, 500, 700, 900, 1200, 1400',
              sizes: '(max-width: 768px) 240px, 520px'
          }}
        </div>
      {% else %}
        <div class="ramblier-coming-soon__logo-text">
          {{ section.settings.brand_name }}
        </div>
      {% endif %}

      {% if section.settings.eyebrow != blank %}
        <p class="ramblier-coming-soon__eyebrow">
          {{ section.settings.eyebrow }}
        </p>
      {% endif %}

      <h1 class="ramblier-coming-soon__heading">
        <span class="ramblier-coming-soon__heading-static">
          Shop exclusive merch
        </span>

        {% if section.settings.heading_prefix != blank %}
          <span class="ramblier-coming-soon__heading-static">
            {{ section.settings.heading_prefix }}
          </span>
        {% endif %}

        <span class="ramblier-coming-soon__heading-dynamic">
          <span class="ramblier-coming-soon__rotating-wrap">
            <span class="js-ramblier-rotating-word ramblier-coming-soon__rotating-word tw-font-dear-jocelyn">
              {% if section.blocks.size > 0 and section.blocks.first.settings.word != blank %}
                {{ section.blocks.first.settings.word }}
              {% else %}
                {{ section.settings.fallback_rotating_word }}
              {% endif %}
            </span>

            <span class="ramblier-coming-soon__drawn-underline" aria-hidden="true">
              <svg viewBox="0 0 154 7" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path
                  d="M1.40234 0.980347C1.7228 4.34032 24.9089 2.12223 26.4746 2.12223C58.1135 2.12223 89.7524 2.12223 121.391 2.12223C131.572 2.12223 141.752 2.12223 151.933 2.12223C154.127 2.12223 153.06 2.66978 151.643 3.20067C142.457 6.6403 131.236 3.26411 121.633 3.26411C102.55 3.26411 83.5991 4.40599 64.5187 4.40599C60.0335 4.40599 55.5482 4.40599 51.0629 4.40599C47.9483 4.40599 44.093 8.1182 44.093 2.12223"
                  stroke="currentColor"
                  stroke-width="1.27735"
                  stroke-linecap="round"
                />
              </svg>
            </span>
          </span>
        </span>

        {% if section.settings.heading_suffix != blank %}
          <span class="ramblier-coming-soon__heading-suffix">
            {{ section.settings.heading_suffix }}
          </span>
        {% endif %}
      </h1>

      {% if section.settings.subheading != blank %}
        <div class="ramblier-coming-soon__subheading">
          {{ section.settings.subheading }}
        </div>
      {% endif %}

      <div class="ramblier-coming-soon__form-wrap">
        <form class="ramblier-coming-soon__form" novalidate>
          <div class="ramblier-coming-soon__form-row">
            <input
              type="email"
              name="email"
              class="ramblier-coming-soon__input"
              placeholder="{{ section.settings.email_placeholder }}"
              autocomplete="email"
              required
            >
            <button
              type="submit"
              class="ramblier-coming-soon__submit"
            >
              {{ section.settings.button_label }}
            </button>
          </div>

          {% if section.settings.form_note != blank %}
            <div class="ramblier-coming-soon__form-note">
              {{ section.settings.form_note }}
            </div>
          {% endif %}

          <div class="ramblier-coming-soon__form-message" aria-live="polite"></div>
        </form>
      </div>

      {% assign has_socials = false %}
      {% if section.settings.pinterest_url != blank
        or section.settings.instagram_url != blank
        or section.settings.tiktok_url != blank
      %}
        {% assign has_socials = true %}
      {% endif %}

      {% if has_socials %}
        <div class="ramblier-coming-soon__socials">
          {% if section.settings.instagram_url != blank %}
            <a
              href="{{ section.settings.instagram_url }}"
              class="ramblier-coming-soon__social-link"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Instagram"
            >
              <span class="ramblier-coming-soon__social-shape">
                <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                  <path d="M7.75 2h8.5A5.75 5.75 0 0 1 22 7.75v8.5A5.75 5.75 0 0 1 16.25 22h-8.5A5.75 5.75 0 0 1 2 16.25v-8.5A5.75 5.75 0 0 1 7.75 2Zm0 1.8A3.95 3.95 0 0 0 3.8 7.75v8.5a3.95 3.95 0 0 0 3.95 3.95h8.5a3.95 3.95 0 0 0 3.95-3.95v-8.5a3.95 3.95 0 0 0-3.95-3.95Zm8.95 1.35a1.1 1.1 0 1 1 0 2.2 1.1 1.1 0 0 1 0-2.2ZM12 6.4A5.6 5.6 0 1 1 6.4 12 5.6 5.6 0 0 1 12 6.4Zm0 1.8A3.8 3.8 0 1 0 15.8 12 3.8 3.8 0 0 0 12 8.2Z" fill="currentColor"/>
                </svg>
              </span>
            </a>
          {% endif %}

          {% if section.settings.tiktok_url != blank %}
            <a
              href="{{ section.settings.tiktok_url }}"
              class="ramblier-coming-soon__social-link"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="TikTok"
            >
              <span class="ramblier-coming-soon__social-shape">
                <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                  <path d="M14.57 2h2.47c.2 1.7 1.16 3.23 2.63 4.08.87.51 1.88.8 2.93.83v2.53c-1.16-.04-2.3-.31-3.33-.78a7.48 7.48 0 0 1-2.22-1.54l-.01 8.04c0 1.62-.63 3.15-1.79 4.3A6.08 6.08 0 0 1 11 22a6.1 6.1 0 0 1-4.3-1.78A6.04 6.04 0 0 1 5 15.93c0-1.62.63-3.15 1.79-4.3A6.07 6.07 0 0 1 11.1 10c.39 0 .78.04 1.16.12v2.57a3.61 3.61 0 0 0-1.16-.19c-.96 0-1.86.38-2.54 1.05a3.57 3.57 0 0 0-1.05 2.54c0 .96.37 1.86 1.05 2.54A3.57 3.57 0 0 0 11.1 19.7c.96 0 1.86-.37 2.54-1.05a3.57 3.57 0 0 0 1.05-2.54V2Z" fill="currentColor"/>
                </svg>
              </span>
            </a>
          {% endif %}
        </div>
      {% endif %}
    </div>
  </div>

  <style>
    #{{ section_id }} {
  position: relative;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--rcs-bg);
  color: var(--rcs-text);
  padding-top: var(--rcs-top-spacing);
  padding-bottom: var(--rcs-bottom-spacing);
  min-height: 100vh;
  min-height: 100svh;
  min-height: 100dvh;
}

    #{{ section_id }} .page-width {
      width: 100%;
      max-width: var(--rcs-page-width);
      margin: 0 auto;
      padding-left: 24px;
      padding-right: 24px;
    }

    #{{ section_id }} .ramblier-coming-soon__bg {
      position: absolute;
      inset: 0;
      background: linear-gradient(180deg, var(--rcs-bg) 0%, var(--rcs-bg-overlay) 100%);
      z-index: 0;
    }

    #{{ section_id }} .ramblier-coming-soon__bg-image-wrap {
      position: absolute;
      inset: -6%;
      z-index: 1;
      overflow: hidden;
      pointer-events: none;
    }

    #{{ section_id }} .ramblier-coming-soon__bg-image {
      width: 100%;
      height: 100%;
      display: block;
      object-fit: cover;
      object-position: center;
      transform: scale(var(--rcs-bg-image-scale));
      opacity: var(--rcs-bg-image-opacity);
      filter: blur(var(--rcs-bg-image-blur));
    }

    #{{ section_id }} .ramblier-coming-soon__inner {
      position: relative;
      z-index: 2;
      width: 100%;
    }

    #{{ section_id }} .ramblier-coming-soon__content {
      width: 100%;
      max-width: var(--rcs-content-width);
      margin: 0 auto;
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
    }

    #{{ section_id }} .ramblier-coming-soon__logo-wrap {
      width: 100%;
      display: flex;
      justify-content: center;
      margin-bottom: 26px;
    }

    #{{ section_id }} .ramblier-coming-soon__logo-image {
      width: min(100%, var(--rcs-logo-width));
      height: auto;
      display: block;
    }

    #{{ section_id }} .ramblier-coming-soon__logo-text {
      margin-bottom: 26px;
      color: var(--rcs-text);
      font-size: 64px;
      line-height: 0.95;
      font-weight: 700;
      letter-spacing: 0.01em;
      text-transform: uppercase;
    }

    #{{ section_id }} .ramblier-coming-soon__eyebrow {
      margin: 0 0 18px;
      color: var(--rcs-text);
      font-size: var(--rcs-eyebrow-size);
      line-height: 1;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      opacity: 0.95;
    }

    #{{ section_id }} .ramblier-coming-soon__heading {
      margin: 0;
      color: var(--rcs-text);
      font-size: var(--rcs-heading-size);
      line-height: 1;
      letter-spacing: 0;
      display: flex;
      align-items: center;
      flex-wrap: wrap;
      justify-content: center;
      gap: 0.2em 0.26em;
      font-family: "Noto Serif";
    }

    #{{ section_id }} .ramblier-coming-soon__heading-static,
    #{{ section_id }} .ramblier-coming-soon__heading-dynamic,
    #{{ section_id }} .ramblier-coming-soon__heading-suffix {
      display: inline-flex;
      align-items: center;
    }

    #{{ section_id }} .ramblier-coming-soon__heading-dynamic {
      flex: 0 0 auto;
    }

    #{{ section_id }} .ramblier-coming-soon__rotating-wrap {
      position: relative;
      display: inline-flex;
      flex-direction: column;
      align-items: flex-start;
      justify-content: flex-start;
      width: fit-content;
      max-width: 100%;
      overflow: visible;
      padding: 0 0.08em;
    }

    #{{ section_id }} .ramblier-coming-soon__rotating-word {
      display: inline-block;
      width: auto;
      min-width: 0;
      font-size: var(--rcs-rotating-word-size);
      line-height: 0.9;
      font-style: italic;
      font-weight: 500;
      text-transform: none;
      white-space: nowrap;
      vertical-align: baseline;
      font-family: Dear Jocelyn, cursive;
    }

    #{{ section_id }} .ramblier-coming-soon__rotating-word::after {
      content: '';
      display: inline-block;
      width: 1px;
      height: 0.9em;
      margin-left: 0.08em;
      background: currentColor;
      vertical-align: -0.08em;
      animation: ramblierComingSoonBlink 0.9s steps(1) infinite;
    }

    @keyframes ramblierComingSoonBlink {
      0%, 50% {
        opacity: 1;
      }
      50.01%, 100% {
        opacity: 0;
      }
    }

    #{{ section_id }} .ramblier-coming-soon__drawn-underline {
      display: block;
      width: 100%;
      line-height: 0;
      margin-top: 2px;
    }

    #{{ section_id }} .ramblier-coming-soon__drawn-underline svg {
      width: 100%;
      height: auto;
      display: block;
      color: var(--rcs-line);
    }

    #{{ section_id }} .ramblier-coming-soon__subheading {
      margin-top: 16px;
      color: var(--rcs-text);
      font-size: var(--rcs-subheading-size);
      line-height: 1.35;
      opacity: 0.95;
      max-width: 760px;
    }

    #{{ section_id }} .ramblier-coming-soon__subheading p {
      margin: 0;
    }

    #{{ section_id }} .ramblier-coming-soon__form-wrap {
      width: 90%;
      margin-top: 34px;
      max-width: 460px;
    }

    #{{ section_id }} .ramblier-coming-soon__form {
      width: 100%;
    }

    #{{ section_id }} .ramblier-coming-soon__form-row {
      position: relative;
      width: 100%;
      display: flex;
      align-items: flex-end;
      border-bottom: 1px solid var(--rcs-line);
    }

    #{{ section_id }} .ramblier-coming-soon__input {
      width: 100%;
      min-height: 42px;
      background: transparent;
      color: var(--rcs-text);
      border: 0;
      border-radius: 0;
      box-shadow: none;
      outline: none;
      padding: 0 120px 0px 0;
      margin: 0;
      font-size: var(--rcs-form-input-size);
      line-height: 1.2;
      text-align: left;
      appearance: none;
      -webkit-appearance: none;
    }

    #{{ section_id }} .ramblier-coming-soon__input::placeholder {
      color: var(--rcs-muted);
      opacity: 1;
    }

    #{{ section_id }} .ramblier-coming-soon__submit {
      position: absolute;
      right: 0;
      bottom: 12px;
      background: transparent;
      border: 0;
      box-shadow: none;
      color: var(--rcs-text);
      text-transform: uppercase;
      letter-spacing: 0.12em;
      font-size: var(--rcs-form-button-size);
      line-height: 1;
      font-weight: 600;
      padding: 0;
      margin: 0;
      min-height: auto;
      cursor: pointer;
      transition: opacity 0.2s ease, transform 0.2s ease;
    }

    #{{ section_id }} .ramblier-coming-soon__submit:hover {
      opacity: 0.75;
      transform: translateY(-1px);
    }

    #{{ section_id }} .ramblier-coming-soon__form.is-submitting .ramblier-coming-soon__submit {
      opacity: 0.5;
      pointer-events: none;
    }

    #{{ section_id }} .ramblier-coming-soon__form-note {
      margin-top: 12px;
      color: var(--rcs-muted);
      font-size: 13px;
      line-height: 1.5;
      text-align: center;
    }

    #{{ section_id }} .ramblier-coming-soon__form-note p {
      margin: 0;
    }

    #{{ section_id }} .ramblier-coming-soon__form-message {
      min-height: 1.5em;
      margin-top: 16px;
      font-size: 14px;
      line-height: 1.5;
      text-align: center;
      color: var(--rcs-text);
    }

    #{{ section_id }} .ramblier-coming-soon__form-message.is-error {
      color: #ffb3b3;
    }

    #{{ section_id }} .ramblier-coming-soon__form-message.is-success {
      color: var(--rcs-text);
    }

    #{{ section_id }} .ramblier-coming-soon__socials {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 24px;
      flex-wrap: wrap;
      margin-top: 34px;
    }

    #{{ section_id }} .ramblier-coming-soon__social-link {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      color: var(--rcs-text);
      text-decoration: none;
      transition: opacity 0.2s ease, transform 0.2s ease;
    }

    #{{ section_id }} .ramblier-coming-soon__social-link:hover {
      opacity: 0.75;
      transform: translateY(-1px);
    }

    #{{ section_id }} .ramblier-coming-soon__social-shape {
      width: var(--rcs-social-size);
      height: var(--rcs-social-size);
      display: flex;
      align-items: center;
      justify-content: center;
      border: 2px solid var(--rcs-line);
      box-sizing: border-box;
      color: var(--rcs-text);
      background: transparent;
    }

    #{{ section_id }} .ramblier-coming-soon__social-shape svg {
      width: var(--rcs-social-icon-size);
      height: var(--rcs-social-icon-size);
      display: block;
      color: currentColor;
      flex: 0 0 auto;
    }

    @media screen and (max-width: 989px) {
      #{{ section_id }} .ramblier-coming-soon__heading {
        font-size: var(--rcs-heading-mobile-size);
        line-height: 1.02;
      }

      #{{ section_id }} .ramblier-coming-soon__rotating-word {
        font-size: var(--rcs-rotating-word-mobile-size);
      }

      #{{ section_id }} .ramblier-coming-soon__logo-text {
        font-size: 48px;
      }
    }

    @media screen and (max-width: 749px) {
  #{{ section_id }} {
